---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css'; 
import CustomCursor from '../components/CustomCursor.astro';
import Header from '../components/Header.astro';

interface Props {
  title: string;
  lang?: string;
  bodyClass?: string;
  hasPattern?: boolean;
}

const { title, lang = "uk", bodyClass = "", hasPattern = false } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oranienbaum&display=swap" rel="stylesheet">

    <ClientRouter />

    <script is:inline>
      function initTheme() {
        const theme = localStorage.getItem('theme') || 
          (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        
        document.documentElement.classList[theme === 'dark' ? 'add' : 'remove']('dark');

        if (!document.documentElement.style.getPropertyValue('--accent-h')) {
          const hues = [354, 210, 160, 280, 25, 190];
          const randomHue = hues[Math.floor(Math.random() * hues.length)];
          document.documentElement.style.setProperty('--accent-h', randomHue.toString());
        }
      }

      initTheme();
      document.addEventListener('astro:after-swap', initTheme);
    </script>
  </head>
  
  <body class={`relative min-h-screen bg-stone-50 text-zinc-900 dark:bg-zinc-950 dark:text-zinc-300 selection:bg-zinc-900 selection:text-stone-50 dark:selection:bg-zinc-300 dark:selection:text-zinc-950 transition-colors duration-500 overflow-x-hidden ${bodyClass} ${hasPattern ? 'body-with-pattern' : ''}`}>
    
    <CustomCursor />
    <Header />

    <main class="site-wrapper w-full relative z-10 md:pr-16 lg:pr-20">
      <slot />
    </main>

    <script>
      function handleThemeClick() {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      }

      function setup() {
        const themeBtn = document.getElementById('top-theme-toggle');
        if (themeBtn) {
          themeBtn.removeEventListener('click', handleThemeClick);
          themeBtn.addEventListener('click', handleThemeClick);
        }
      }

      document.addEventListener('astro:page-load', setup);
    </script>
  </body>
</html>

<style is:global>
  .body-with-pattern {
    background-image: radial-gradient(rgba(0, 0, 0, 0.1) 1px, transparent 1px);
    background-size: 24px 24px;
    background-position: 0 0;
  }
  
  html.dark .body-with-pattern {
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
  }
</style>