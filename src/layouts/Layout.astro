---
// src/layouts/Layout.astro
import { getCollection } from "astro:content";
import "../styles/global.css";

const settingsCollection = await getCollection("settings");
const globalSettings = settingsCollection[0]?.data || {
	siteTitle: "PUSHKAREFF Production",
	siteDescription_uk: "Дизайн та продакшн студія",
	ogImage: "/images/seo/default-og.jpg",
};

interface Props {
	title?: string;
	description?: string;
	image?: string;
	lang?: "uk" | "en";
}

const { title, description, image, lang = "uk" } = Astro.props;

const finalTitle = title
	? `${title} | ${globalSettings.siteTitle}`
	: globalSettings.siteTitle;
const globalDesc =
	lang === "uk"
		? globalSettings.siteDescription_uk
		: globalSettings.siteDescription_en;
const finalDescription = description || globalDesc || "";
const finalImage = image || globalSettings.ogImage || "";

// Двомовні тексти для перемикача
const themeDarkText = lang === "uk" ? "● ТЕМНА ТЕМА" : "● DARK MODE";
const themeLightText = lang === "uk" ? "○ СВІТЛА ТЕМА" : "○ LIGHT MODE";
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<title>{finalTitle}</title>
		<meta name="description" content={finalDescription} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=Inter:wght@400;700&display=swap"
			rel="stylesheet"
		/>

		<script is:inline>
			const theme = (() => {
				if (
					typeof localStorage !== "undefined" &&
					localStorage.getItem("theme")
				) {
					return localStorage.getItem("theme");
				}
				if (window.matchMedia("(prefers-color-scheme: dark)").matches)
					return "dark";
				return "light";
			})();
			if (theme === "dark")
				document.documentElement.classList.add("dark");
		</script>
	</head>

	<body class="relative">
		<div id="magic-cursor" class="magic-cursor hidden md:block"></div>
		
		<nav class="top-nav">
			<div class="nav-links-group">
				<a href="/" class={`nav-link ${lang === 'uk' ? 'is-active' : 'is-inactive'}`}>UK</a>
				<a href="/en" class={`nav-link ${lang === 'en' ? 'is-active' : 'is-inactive'}`}>EN</a>
			</div>
			
			<button id="top-theme-toggle" class="theme-toggle-btn">
				<span class="dark:hidden">{themeDarkText}</span>
				<span class="hidden dark:inline text-white">{themeLightText}</span>
			</button>
		</nav>

		<slot />

		<script src="../scripts/app.js"></script>
	</body>
</html>
