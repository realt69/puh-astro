---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import EditorialLayout from '../../layouts/EditorialLayout.astro';

export async function getStaticPaths() {
  const worksEntries = await getCollection('works');
  return worksEntries.map(entry => ({
    params: { slug: entry.id }, // У Astro 6 використовується id замість slug
    props: { entry },
  }));
}

const { entry } = Astro.props;
// ЦЕЙ РЯДОК КРИТИЧНО ВАЖЛИВИЙ: Він дістає контент з Markdown/MDX
const { Content } = await render(entry);

const title = entry.data.title_uk || "Проєкт";
const coverImage = entry.data.coverImage_uk;
const category = entry.data.category;
const studio = "Pushkareff Production";
const author = "Віталій Пушкарьов";
---

<EditorialLayout title={`${title} — PUSHKAREFF`}>
  <article class="w-full px-6 md:px-12 mt-25 pb-30">
    
    <header class="mb-12">
      <h1 class="font-serif text-3xl md:text-5xl leading-[1.1] tracking-tight uppercase max-w-225">
        {title}
      </h1>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-4 lg:grid-cols-5 gap-x-12 gap-y-12 lg:gap-y-16">
      
      {coverImage && (
        <figure class="w-full overflow-hidden bg-zinc-900 shadow-xl md:col-span-4 lg:col-start-2 lg:col-span-4 lg:row-start-1">
          <Image 
            src={coverImage} 
            alt={title} 
            width={1600} 
            height={900}
            class="w-full h-auto object-cover"
          />
        </figure>
      )}

      <aside class="hidden md:flex flex-col font-mono uppercase tracking-[0.15em] pt-4 border-t border-zinc-900/10 dark:border-white/10 self-start sticky top-25 z-20 md:col-span-1 md:row-start-2 lg:col-start-1 lg:row-start-1 lg:row-span-2">
        <div class="space-y-8">
          <div>
            <span class="block text-[9px] opacity-40 mb-2">Author</span>
            <span class="text-[12px] font-bold leading-none">{author}</span>
          </div>
          <div>
            <span class="block text-[9px] opacity-40 mb-2">Studio</span>
            <span class="text-[12px] leading-none">{studio}</span>
          </div>
        </div>
      </aside>

      <div class="editorial-prose text-[12px] leading-normal lg:text-[14px] lg:leading-[1.6] text-zinc-900 dark:text-zinc-300 md:col-span-3 md:row-start-2 lg:col-start-2 lg:col-span-4 lg:row-start-2 lg:columns-2 lg:gap-x-16">
        <Content />
      </div>

    </div>
  </article>
</EditorialLayout>
<style>
  .editorial-prose :global(p) {
    margin-bottom: 24px;
    text-align: justify;
    text-justify: inter-word;
    break-inside: avoid;
    text-wrap: pretty;
  }

  .editorial-prose :global(blockquote) {
    font-family: var(--font-oranienbaum);
    font-style: italic;
    font-size: 1.2em; 
    line-height: 1.5;
    margin: 32px 0;
    padding: 24px;
    text-align: left;
    border-left: 2px solid hsl(var(--accent-h), 80%, 45%);
    background-color: color-mix(in srgb, var(--accent), transparent 97%);
    break-inside: avoid;
  }

  .editorial-prose :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .editorial-prose :global(h2) {
    font-family: var(--font-oranienbaum);
    font-size: 1.5em;
    margin-top: 48px;
    margin-bottom: 24px;
    line-height: 1.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    break-after: avoid;
  }

  /* ОНОВЛЕНИЙ БЛОК БУКВИЦІ */
  .editorial-prose > :global(p:first-of-type)::first-letter {
    font-family: var(--font-oranienbaum);
    initial-letter: 3;
    -webkit-initial-letter: 3;
    float: left;
    margin-right: 12px;
    margin-top: 0;
    color: hsl(var(--accent-h), 80%, 45%);
    /* Невеликий padding-top для тонкого налаштування, якщо initial-letter не ідеально вирівнює верх */
    padding-top: 4px; 
  }
</style>