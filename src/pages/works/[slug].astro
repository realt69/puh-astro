---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';

// 1. Кажемо Astro згенерувати сторінки для всіх проєктів
export async function getStaticPaths() {
	const works = await getCollection('works');
	return works.map(work => ({
		params: { slug: work.id },
		props: { work },
	}));
}

// 2. Отримуємо дані поточного проєкту
const { work } = Astro.props;

// 3. Рендеримо текст із MDX-редактора
const { Content } = await render(work);

// Словник для красивого виводу категорії
const categoryMap: Record<string, string> = {
	'print': 'Дизайн поліграфії',
	'web': 'Розробка сайтів',
	'brand': 'Розробка бренду',
	'3d': '3D простір'
};
const categoryLabel = work.data.category ? categoryMap[work.data.category] : '';
---

<Layout 
	title={work.data.title_uk} 
	description={work.data.description_uk} 
	image={work.data.coverImage_uk?.src}
>
	<main class="pb-32">
		
		{work.data.coverImage_uk && (
			<section class="w-full h-[70vh] md:h-screen relative">
				<Image 
					src={work.data.coverImage_uk} 
					alt={work.data.title_uk}
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-black/30"></div>
			</section>
		)}

		<section class="max-w-400 mx-auto px-6 md:px-12 py-20">
			<div class="grid md:grid-cols-12 gap-12">
				
				<div class="md:col-span-8">
					<p class="text-sm font-mono text-gray-500 uppercase tracking-widest mb-4">
						[ {categoryLabel} ]
					</p>
					<h1 class="text-5xl md:text-7xl font-black uppercase leading-none mb-12">
						{work.data.title_uk}
					</h1>
					
					<div class="prose prose-lg max-w-none text-gray-800">
						<Content />
					</div>
				</div>

				<div class="md:col-span-4 flex flex-col gap-6 border-t md:border-t-0 md:border-l border-gray-300 pt-8 md:pt-0 md:pl-12 text-sm font-mono">
					
					{work.data.location_uk && (
						<div>
							<span class="text-gray-500 block mb-1">Локація:</span>
							<span class="uppercase">{work.data.location_uk}</span>
						</div>
					)}
					
					{work.data.orientation && (
						<div>
							<span class="text-gray-500 block mb-1">Орієнтація:</span>
							<span class="uppercase">{work.data.orientation}</span>
						</div>
					)}

					{work.data.aspectRatio && (
						<div>
							<span class="text-gray-500 block mb-1">Співвідношення:</span>
							<span class="uppercase">{work.data.aspectRatio}</span>
						</div>
					)}

					{work.data.projectUrl && (
						<div class="mt-4">
							<a 
								href={work.data.projectUrl} 
								target="_blank" 
								rel="noopener noreferrer"
								class="inline-block border border-black px-6 py-3 uppercase hover:bg-black hover:text-white transition-colors"
							>
								Перейти на сайт ↗
							</a>
						</div>
					)}
				</div>

			</div>
		</section>

		{work.data.youtubeId && (
			<section class="max-w-400 mx-auto px-6 md:px-12 py-10">
				<div class="aspect-video w-full bg-gray-200">
					<iframe 
						class="w-full h-full"
						src={`https://www.youtube.com/embed/${work.data.youtubeId}`} 
						title="YouTube video player" 
						frameborder="0" 
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
						allowfullscreen
					></iframe>
				</div>
			</section>
		)}

		{(work.data.desktopDesign || work.data.tabletDesign || work.data.phoneDesign) && (
			<section class="max-w-400 mx-auto px-6 md:px-12 py-20 bg-gray-50 my-20">
				<h3 class="text-2xl font-bold uppercase mb-12 text-center">Адаптивний дизайн</h3>
				<div class="flex flex-col items-center gap-12">
					{work.data.desktopDesign && (
						<div class="w-full max-w-5xl shadow-2xl">
							<Image src={work.data.desktopDesign} alt="Desktop Design" class="w-full h-auto" />
						</div>
					)}
					<div class="flex flex-col md:flex-row gap-8 justify-center items-end">
						{work.data.tabletDesign && (
							<div class="w-full max-w-md shadow-xl">
								<Image src={work.data.tabletDesign} alt="Tablet Design" class="w-full h-auto" />
							</div>
						)}
						{work.data.phoneDesign && (
							<div class="w-full max-w-xs shadow-lg">
								<Image src={work.data.phoneDesign} alt="Phone Design" class="w-full h-auto" />
							</div>
						)}
					</div>
				</div>
			</section>
		)}

		{work.data.gallery && work.data.gallery.length > 0 && (
			<section class="max-w-400 mx-auto px-6 md:px-12 py-20">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{work.data.gallery.map((img) => (
						<div class="aspect-square bg-gray-100 overflow-hidden">
							<Image 
								src={img} 
								alt="Gallery image" 
								class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
							/>
						</div>
					))}
				</div>
			</section>
		)}

	</main>
</Layout>