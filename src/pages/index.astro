---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import '../styles/home.css';

const works = await getCollection("works");
works.sort(
	(a, b) =>
		(b.data.publishDate?.getTime() || 0) -
		(a.data.publishDate?.getTime() || 0),
);

const coverStory = works[0];

const categoryMap: Record<string, string> = {
	print: "Дизайн поліграфії",
	web: "Розробка сайтів",
	brand: "Розробка бренду",
	"3d": "3D простір",
};
const allCategories = Object.keys(categoryMap);

let issueDateStr = "";
if (coverStory?.data.publishDate) {
    const dateObj = new Date(coverStory.data.publishDate);
    
    // Отримуємо назву місяця українською (з малої літери)
    const month = new Intl.DateTimeFormat("uk-UA", { month: "long" })
        .format(dateObj)
        .toLowerCase();
        
    // Отримуємо дві останні цифри року
    const year = dateObj.getFullYear().toString().slice(-2);
    
    // Збираємо все разом з елегантним апострофом
    issueDateStr = `${month} '${year}`;
}
---

<Layout lang="uk">
	<main class="main-wrapper">
		<div id="magazine-cover" class="magazine-cover">
			{
				coverStory && (
					<>
						<div class="glossy-overlay" />
						<header class="cover-header">
							<div class="logo-container">
								<img
									src="/logo.svg"
									alt="LOGO"
									class="logo-image"
								/>
							</div>
							<div class="issue-date-wrapper">
								<div class="issue-date">{issueDateStr}</div>
							</div>
						</header>

						<div class="hero-image-container">
							{coverStory.data.coverImage_uk && (
								<Image
									src={coverStory.data.coverImage_uk}
									alt=""
									width={1600}
									class="hero-image"
								/>
							)}
						</div>

						<nav class="categories-nav">
							{allCategories.map((cat) => (
								<a
									href={`/category/${cat}`}
									class={`category-pill ${cat === coverStory.data.category ? "is-active" : "is-inactive"}`}
								>
									{categoryMap[cat]}
								</a>
							))}
						</nav>

						<a
							href={`/works/${coverStory.id}`}
							class="cover-footer group"
						>
							<p class="featured-label">[ featured case ]</p>
							<h2 class="cover-title">
								{coverStory.data.title_uk}
							</h2>
							<span class="read-more-btn">
								[ розгорнути кейс ]
							</span>
						</a>
					</>
				)
			}
		</div>
	</main>
</Layout>
